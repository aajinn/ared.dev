# Supabase – get these from your project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key (secret — NEVER use NEXT_PUBLIC_ prefix or expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Admin panel – choose a strong random key
ADMIN_KEY=change-this-to-a-random-secret

# Contact form SMTP (e.g. Gmail app password) — recipient is set in admin panel
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
